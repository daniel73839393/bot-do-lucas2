# Obrigatórios — do Discord Developer Portal
DISCORD_BOT_TOKEN=cole_seu_token_aqui
DISCORD_CLIENT_ID=cole_o_application_id_aqui

# Obrigatório se quiser /imagine, /search e /embedai (pegue em platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# Obrigatório se quiser /imagine-gemini (pegue grátis em aistudio.google.com/apikey)
GEMINI_API_KEY=AIza...

# Opcional — para /imagine-grok (pegue em console.x.ai)
# GROK_API_KEY=xai-...
